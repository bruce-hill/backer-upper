{
  "productName": "Backer-Upper",
  "version": "0.1.0",
  "identifier": "com.brucehill.backer-upper",
  "build": {
    "frontendDist": "../ui",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
